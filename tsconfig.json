{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".eslintrc.cjs"
  ],
  "compilerOptions": {
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "types": ["@remix-run/node"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "target": "ES2022",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "noEmit": true,
    "skipLibCheck": true
  }
}
